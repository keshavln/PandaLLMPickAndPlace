<mujoco model="neon_cross">
  <worldbody>
  <!-- robosuite/models/objects.py requires that everything be nested within an extra body tag. -->
  <body>
    <body name="object">
      <geom name="cross_x_vis" type="box" size="0.05 0.005 0.0005" group="1" contype="0" conaffinity="0" rgba="0.1 1.0 0.1 1"/>
      <geom name="cross_y_vis" type="box" size="0.005 0.05 0.0005" group="1" contype="0" conaffinity="0" rgba="0.1 1.0 0.1 1"/>
      <geom name="cross_x_col" type="box" size="0.05 0.005 0.0005" group="0" friction="1 0.005 0.0001"/>
      <geom name="cross_y_col" type="box" size="0.005 0.05 0.0005" group="0" friction="1 0.005 0.0001"/>
    </body>

    <!--
    The site tags specify the approximate bounding volume for the object.
    This is to make sure that other objects cannot spawn inside the object or cause an overlap.
    -->
    
    <site name="bottom_site" pos="0 0 -0.0005" rgba="0 0 0 0" size="0.001"/>
    <site name="top_site" pos="0 0 0.0005" rgba="0 0 0 0" size="0.001"/>
    <site name="horizontal_radius_site" pos="0.015 0 0" rgba="0 0 0 0" size="0.001"/>

  </body>
  </worldbody>
</mujoco>